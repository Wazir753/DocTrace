{
  "name": "doctrace",
  "version": "1.0.0",
  "description": "Google Docs student writing effort analyzer - detect AI usage and analyze genuine writing effort",
  "author": "ScriptSense Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "setup": "node scripts/generate-icons.js",
    "dev": "npm run setup && webpack --mode development --watch",
    "build": "npm run setup && webpack --mode production",
    "start": "npm run dev",
    "lint": "eslint src --fix",
    "format": "prettier --write src/**/*.{js,jsx,json,css}"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "copy-webpack-plugin": "^11.0.0",
    "html-webpack-plugin": "^5.5.4",
    "eslint": "^8.51.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-react": "^7.33.2",
    "prettier": "^3.0.3"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}
